{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["{", "}"],
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}", "notIn": ["string", "comment"] },
    { "open": "(", "close": ")", "notIn": ["string", "comment"] },
    { "open": "[", "close": "]", "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""],
    ["'", "'"],
    ["<", ">"]
  ],
  "autoIndent": "full",
  "indentationRules": {
    "increaseIndentPattern": "^.*\\{\\s*(//.*)?$",
    "decreaseIndentPattern": "^\\s*\\}"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*//.*$",
      "action": { "indent": "none", "appendText": "// " }
    }
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "folding": {
    "markers": {
      "start": "\\{",
      "end": "\\}"
    }
  }
}
